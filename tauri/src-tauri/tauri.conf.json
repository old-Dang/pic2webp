{
  "$schema": "https://raw.githubusercontent.com/nicovrc/tauri-settings-schema/refs/heads/v2/schema.json",
  "productName": "Pic2WebP",
  "version": "1.0.0",
  "identifier": "com.danglei.pic2webp",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Pic2WebP - 图片转 WebP",
        "width": 760,
        "height": 560,
        "minWidth": 640,
        "minHeight": 480,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../tools/*"
    ]
  }
}
